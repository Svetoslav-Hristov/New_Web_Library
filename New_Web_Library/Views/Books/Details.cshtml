@model FullPreviewModelBook
@{
    ViewData["Title"] = "Book Details";
    
    var message = TempData["SuccessMessage"] as string;

    var successReservation = TempData["SuccessReservation"] as string;

}


@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-success" role="alert">
        @message
    </div>

}

@if (!string.IsNullOrEmpty(successReservation))
{
    <div class="alert alert-success" role="alert">
        @successReservation
    </div>

}
<div class="container">
    <h2 class="mb-4">Book Details</h2>

    <div class="container mt-4">
        <div class="row">
            <div class="col-md-4 text-center">
                <img src="~/Images/@Model.CoverImageUrl"
                     alt="Book cover"
                     class="img-fluid rounded shadow" />
            </div>

            <div class="col-md-8">
                <h2>@Model.Title</h2>
                <h5 class="text-muted">by @Model.AuthorName</h5>
                <p>Year of published: @Model.YearOfPublished</p>
                <p>Genre: @Model.Genre</p>
                <hr />
                <p>@Model.Description</p>
            </div>
        </div>
    </div>

    <hr />
    
    <div class="d-flex justify-content-between">
       
        <div class="d-flex gap-2">
            <a asp-controller="Books"
               asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-outline-warning">
                Edit
            </a>

            <form asp-controller="Books"
                  asp-action="Delete"
                  asp-route-id="@Model.Id"
                  method="post"
                  onsubmit="return confirm('Are you sure you want to delete this book?');">

                <button type="submit"
                        class="btn btn-outline-danger">
                    Delete
                </button>
            </form>
        </div>

        <div>
            <a asp-controller="Books"
               asp-action="Index"
               class="btn btn-outline-success">
                BooksCatalog
            </a>
            
            @if(Model.BookStatus==BookStatus.Returned || Model.BookStatus==BookStatus.Expired)
           { 
            <a asp-controller="Systems"
               asp-action="CreateReservation"
               asp-route-bookId="@Model.Id"
               class="btn btn-outline-primary">
                Reserve
                </a>
            }
            else
            {
                <a class="btn btn-outline-secondary disabled">
                    Not available
                </a>
            }
        </div>

    </div>
</div>

