@model IEnumerable<RegisterModelView>
@{
    var message = TempData["NotAvailable"] as string;

    var blockedUser = TempData["IncorrectUser"] as string;

    var failEdit = TempData["Unchanged"] as string;

    var editLoan = TempData["ConfirmOrEdit"] as string;

}

@if (!string.IsNullOrEmpty(message))
{
    <div class="alert alert-danger" role="alert">
        @message
    </div>

}
@if (!string.IsNullOrEmpty(blockedUser))
{
    <div class="alert alert-danger" role="alert">
        @blockedUser
    </div>

}

@if (!string.IsNullOrEmpty(failEdit))
{
    <div class="alert alert-danger" role="alert">
        @failEdit
    </div>

}

@if (!string.IsNullOrEmpty(editLoan))
{
    <div class="alert alert-success" role="alert">
        @editLoan
    </div>

}
<div class="container-fluid px-0">
    <div class="row g-0">
        <aside class="col-md-3 col-lg-2 bg-light border-end min-vh-100 p-3">
            <h5 class="mb-3">Menu</h5>

            <div class="d-flex flex-column gap-2">
                <a asp-controller="Users"
                   asp-action="Index"
                   class="btn btn-outline-primary">
                    👤 Users List
                </a>
                <a class="btn btn-outline-primary" asp-controller="Users" asp-action="Create">
                    + Add User
                </a>

                <a asp-controller="Books"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    📚 Books
                </a>
                <a class="btn btn-outline-primary"
                   asp-controller="Books"
                   asp-action="Create">
                    + Add Book
                </a>
                <a asp-controller="Systems"
                   asp-action="CreateLoan"
                   class="btn btn-outline-success">
                    ➕ Create Loan
                </a>

            </div>
        </aside>
        <main class="col-md-9 col-lg-10 p-4">

            <h2 class="mb-4">📚 Borrowed Books Register</h2>

           
            <form method="get" class="mb-3">
                <div class="input-group">
                    <input type="text"
                           name="search"
                           class="form-control"
                           placeholder="Search by user name..."
                           value="@Context.Request.Query["search"]" />

                    <button class="btn btn-outline-primary" type="submit">
                        Search
                    </button>
                </div>
            </form>

            @if (!Model.Any())
            {
                <div class="alert alert-info">
                    No records found.
                </div>
            }
            else
            {
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>User</th>
                            <th>Book</th>
                            <th>Pick-up date / ReservedOn</th>
                            <th>Return date / ReservationExpiresOn</th>
                            <th>Status</th>
                            <th>Edit Loan</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Users"
                                       asp-action="Details"
                                       asp-route-id="@item.UserId">
                                        @item.UserFirstName @item.UserLastName
                                    </a>
                                </td>

                                <td>
                                    <a asp-controller="Books"
                                       asp-action="Details"
                                       asp-route-id="@item.BookId">
                                        @item.BookTitle
                                    </a>
                                </td>
                                @if (item.PickUpDate != null && item.ReturnDate != null)
                                {
                                    <td>@(item.PickUpDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                                    <td>@(item.ReturnDate?.ToString("dd.MM.yyyy") ?? "-")</td>
                                    <td>
                                        <span class="badge bg-success">@item.Status</span>
                                    </td>
                                }
                                else
                                {
                                    <td>@(item.ReservedOn?.ToString("dd.MM.yyyy") ?? "-")</td>
                                    <td>@(item.ReservationExpiresOn?.ToString("dd.MM.yyyy") ?? "-")</td>
                                    <td>
                                        <span class="badge bg-warning">@item.Status</span>
                                    </td>
                                }

                                
                                @if (item.PickUpDate != null)
                                {
                                    <td>
                                        <a asp-controller="Systems"
                                           asp-action="EditLoan"
                                           asp-route-id=" @item.LoanId "
                                           class="btn btn-outline-warning">
                                            Edit
                                        </a>

                                    </td>
                                }
                                else
                                {
                                    <td>
                                        <a asp-controller="Systems"
                                           asp-action="EditLoan"
                                           asp-route-id=" @item.LoanId "
                                           class="btn btn-outline-primary">
                                            ConfirmLoan
                                        </a>

                                    </td>

                                }
                                <td>
                                    <form asp-controller="Systems"
                                          asp-action="DeleteLoan"
                                          asp-route-id="@item.LoanId"
                                          method="post"
                                          onsubmit="return confirm('Are you sure you want to delete this LoanRecord?');">

                                        <button type="submit" class="btn btn btn-outline-danger ">
                                            Delete Loan
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

        </main>

    </div>
</div>
