@model CreateLoanView


<div class="container">
    <h2 class="mb-4">Loan Form</h2>
    
        <form asp-action="CreateLoan" method="post">

            <div class="mb-3">
                <label class="form-label">User</label>
                <select class="form-select"
                        asp-for="UserId"
                        asp-items="Model.UsersList">
                    <option value="">-- Select a user --</option>
                </select>
                <span asp-validation-for="UserId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Book</label>
                <select class="form-select"
                        asp-for="BookId"
                        asp-items="Model.BookList">
                    <option value="">-- Select a book --</option>
                </select>
                <span asp-validation-for="BookId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Pick-up date</label>
                <input class="form-control"
                       value="@DateOnly.FromDateTime(DateTime.Now).ToString("dd/MM/yyyy")"
                       readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">Return date</label>
                <input class="form-control"
                       value="@DateOnly.FromDateTime(DateTime.Now).AddDays(25).ToString("dd/MM/yyyy")"
                       readonly />
            </div>

            <button type="submit" class="btn btn-primary">
                Confirm Loan
            </button>
            <a class="btn btn-secondary" asp-controller="Systems" asp-action="Register">Cancel</a>

        </form>

   
</div>